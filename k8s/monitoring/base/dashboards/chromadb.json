        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"juiceshop-chatbot\", pod=~\".*chromadb.*\", container!=\"\", container!=\"POD\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
