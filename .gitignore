# OWASP Juice Shop Chatbot — .gitignore

# Nested accidental clone / duplicate tree
/owasp-juiceshop-chatbot/

# Secrets & env (never commit)
.env
.env.*
!.env.example
!.env*.example
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*
*.crt
credentials.json
**/secrets/**/*.yaml
!**/secret.example.yaml

# Python
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
.venv/
backend/.venv/
ai-assistant/.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.tox/
.nox/

# Node / frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.angular/
.nyc_output/
.sass-cache/

# Build / caches
build/
dist/
tmp/
.cache/
cache/
coverage/
logs/
*.log
*.orig
*.out
/bom.json
/bom.xml
JSON
JSON.map
frontend/src/**/*.js

# Local data / DBs
*.sqlite
*.sqlite-journal
/data/juiceshop.sqlite-journal
/data/kind/
chroma_data/
**/chroma/

# App runtime
order_*.pdf
app/
!frontend/src/app
uploads/complaints/*.*
!uploads/complaints/.gitkeep
ftp/legal.md
package-lock.json
i18n/*.json
i18n/*.invalid
!frontend/src/assets/i18n/*.json
!data/static/i18n/*.json

# Config overlays (keep defaults)
config/*.yml
!config/addo.yml
!config/bodgeit.yml
!config/ctf.yml
!config/fbctf.yml
!config/default.yml
!config/juicebox.yml
!config/quiet.yml
!config/test.yml
!config/7ms.yml
!config/mozilla.yml
!config/unsafe.yml
!config/tutorial.yml
!config/oss.yml
!config/defcon33.yml

# IDE / OS
.idea/
.vscode/
.DS_Store
*.eml
*.iml
*.iws
*.swp
out/
.ai/mcp/mcp.json
.junie/memory/
.junie/plans/
.playwright-mcp/
.colima/
.cursor/

# Tests / screenshots
cypress/screenshots/
cypress/videos/
vagrant/.vagrant/

# gh-pages assets quirk (upstream)
assets/
!frontend/src/assets/
