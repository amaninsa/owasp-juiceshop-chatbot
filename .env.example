# Copy to .env.openai (gitignored) — never commit real keys.
OPEN_AI_KEY=

# Optional compose overrides (copy to .env if desired)
GATEWAY_PUBLISH_PORT=3000
AI_ASSISTANT_PUBLISH_PORT=8000
CHROMA_PUBLISH_PORT=8001
AI_ASSISTANT_PORT=8000
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
INGEST_ON_STARTUP=true
INGEST_RESET=true
CHROMA_WAIT_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
LOG_JSON=true
